{
  "name": "nestjs-cli4",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS + Prisma + MySQL example project",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:staging": "APP_ENV=staging ts-node-dev --respawn --transpile-only src/main.ts",
    "start:prod": "APP_ENV=prod node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:staging": "APP_ENV=staging prisma generate",
    "prisma:generate:prod": "APP_ENV=prod prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:staging": "APP_ENV=staging prisma migrate dev",
    "prisma:migrate:prod": "APP_ENV=prod prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.18",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
